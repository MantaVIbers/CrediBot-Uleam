# =============================================================================
# CrediBot — Variables de entorno (plantilla)
# Copiar a .env:  copy .env.example .env   (Windows)
#                  cp .env.example .env     (Linux/macOS)
# =============================================================================

# --- App ---
APP_NAME=CrediBot
APP_ENV=development
APP_DEBUG=true
APP_PUBLIC_URL=http://localhost:8000

# --- Supabase (PostgreSQL + API) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Redis (opcional; sin URL usa memoria local) ---
REDIS_URL=
REDIS_SESSION_TTL_SECONDS=3600

# --- Proveedor WhatsApp: twilio | meta ---
WHATSAPP_PROVIDER=twilio

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# false en local / ngrok; true en Render con webhook público
TWILIO_VALIDATE_SIGNATURE=false

# --- Meta WhatsApp Cloud API (si WHATSAPP_PROVIDER=meta) ---
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=
META_GRAPH_API_VERSION=v21.0

# --- Regional ---
DEFAULT_COUNTRY_CODE=593

# --- Panel Streamlit (solo dashboard, no el backend FastAPI) ---
ADMIN_DASHBOARD_PASSWORD=change-this-password

# --- OpenAI (normalización IA, RAG, agente modo información) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# false = solo reglas locales sin llamar a OpenAI
OPENAI_ENABLE_AI=true
